{
  "name": "voxta-sprite-studio",
  "private": true,
  "version": "0.1.0",
  "description": "Turn a character image into a transparent WebM ready for Voxta's stage",
  "author": "Voxta Scientist",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.voxta.spritestudio",
    "productName": "Voxta Sprite Studio",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "python/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "python/**"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    }
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "extract-zip": "^2.0.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-solid": "^0.563.0",
    "sass": "^1.97.3",
    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "concurrently": "^9.1.0",
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0",
    "typescript": "~5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.10",
    "wait-on": "^8.0.1"
  }
}
